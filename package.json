{
  "name": "nowhere-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w @nowhere/frontend",
    "build": "npm run build -w @nowhere/core && npm run build -w @nowhere/frontend",
    "preview": "npm run preview -w @nowhere/frontend",
    "build:core": "npm run build -w @nowhere/core",
    "build:frontend": "npm run build -w @nowhere/frontend",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d packages/frontend/dist"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "typescript": "^5.6.2"
  }
}
